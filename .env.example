ENVIRONMENT=development
DEBUG=true
DATABASE_URL=sqlite:///./api_applier.db
SECRET_KEY=replace-with-a-long-random-string
ENCRYPTION_SECRET=replace-with-another-long-random-string-min-32-chars
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
FRONTEND_URL=http://localhost:5173

# Storage: local | s3
STORAGE_BACKEND=local
STORAGE_DIR=storage
# S3 (when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_PREFIX=

# Redis
REDIS_URL=redis://localhost:6379/0

# Rate / abuse limits
RATE_LIMIT_PER_MINUTE=120
SEARCH_RUNS_PER_HOUR=10
LOGIN_FAIL_LIMIT=5
LOGIN_FAIL_WINDOW_SECONDS=900
ACCESS_TOKEN_EXPIRE_MINUTES=60

ADMIN_EMAIL=patel.prerak2798@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=patel.prerak2798@gmail.com
SMTP_PASSWORD=replace-with-smtp-app-password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=patel.prerak2798@gmail.com

DEFAULT_OPENAI_MODEL=gpt-5.2
DEFAULT_ANTHROPIC_MODEL=claude-opus-4-7
